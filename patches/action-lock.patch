+NS_IMETHODIMP
+nsDocShell::SuspendPage() {
+  if (mSuspendedForActionLock)
+    return NS_OK;
+  mSuspendedForActionLock = true;
+
+  // Freeze refresh driver (stops layout, paint, CSS animations, rAF)
+  if (RefPtr<nsPresContext> pc = GetPresContext()) {
+    pc->RefreshDriver()->Freeze();
+  }
+
+  // Suspend timeouts, intervals, and network event delivery
+  if (nsPIDOMWindowOuter* outer = GetWindow()) {
+    if (nsPIDOMWindowInner* inner = outer->GetCurrentInnerWindow()) {
+      inner->Suspend();
+    }
+  }
+
+  // Suppress event handling (mouse, keyboard, etc.)
+  if (RefPtr<PresShell> presShell = GetPresShell()) {
+    presShell->SuppressEventHandling();
+  }
+
+  return NS_OK;
+}
+
+NS_IMETHODIMP
+nsDocShell::ResumePage() {
+  if (!mSuspendedForActionLock)
+    return NS_OK;
+  mSuspendedForActionLock = false;
+
+  if (RefPtr<PresShell> presShell = GetPresShell()) {
+    presShell->UnsuppressEventHandling();
+  }
+
+  if (nsPIDOMWindowOuter* outer = GetWindow()) {
+    if (nsPIDOMWindowInner* inner = outer->GetCurrentInnerWindow()) {
+      inner->Resume();
+    }
+  }
+
+  if (RefPtr<nsPresContext> pc = GetPresContext()) {
+    pc->RefreshDriver()->Thaw();
+  }
+
+  return NS_OK;
+}

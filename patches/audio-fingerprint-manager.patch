+#ifndef mozilla_dom_AudioFingerprintManager_h
+#define mozilla_dom_AudioFingerprintManager_h
+
+#include "nsString.h"
+#include <algorithm>
+
+// Forward declarations for WebIDL binding (avoid js/TypeDecls.h namespace pollution)
+struct JSContext;
+class JSObject;
+
+class nsPIDOMWindowInner;
+
+namespace mozilla {
+namespace dom {
+
+class AudioFingerprintManager {
+ public:
+  static uint32_t GetUserContextIdFromWindow(nsPIDOMWindowInner* aWindow);
+
+  static void SetSeed(uint32_t aUserContextId, uint32_t aSeed);
+  static uint32_t GetSeed(uint32_t aUserContextId);
+
+  // Apply transformation to float audio data (for getChannelData, copyFromChannel, AnalyserNode float methods)
+  static void ApplyTransformation(float* data, uint32_t length, uint32_t seed);
+
+  // Apply transformation to byte audio data (for AnalyserNode byte methods)
+  static void ApplyTransformationToBytes(uint8_t* data, uint32_t length, uint32_t seed);
+
+  static bool IsFunctionEnabledForWebIDL(JSContext* aCx, JSObject* aObj);
+};
+
+}  // namespace dom
+}  // namespace mozilla
+
+#endif  // mozilla_dom_AudioFingerprintManager_h


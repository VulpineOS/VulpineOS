# VulpineOS Vulpine-Box: One-click Agent OS container
# Usage: docker build -f Dockerfile.vulpinebox -t vulpineos .
#        docker run -p 8443:8443 -e VULPINE_API_KEY=secret vulpineos

# Stage 1: Build Go binary
FROM golang:1.26-bookworm AS go-builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY cmd/ cmd/
COPY internal/ internal/
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags="-s -w" -o /vulpineos ./cmd/vulpineos/

# Stage 2: Runtime
FROM ubuntu:22.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    gnupg \
    ca-certificates curl \
    && install -d -m 0755 /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update && apt-get install -y --no-install-recommends \
    libgtk-3-0 libdbus-glib-1-2 libxt6 libasound2 \
    libx11-xcb1 libxcomposite1 libxdamage1 libxrandr2 \
    libxext6 libxfixes3 libxcursor1 libxi6 \
    fonts-liberation fonts-noto-color-emoji \
    nodejs xvfb \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/vulpineos

# Install OpenClaw where the runtime manager can discover it.
COPY package.json package-lock.json ./
RUN npm ci --omit=dev && npm cache clean --force

# Copy pre-built Camoufox distribution (must be in dist/camoufox-linux/)
COPY dist/camoufox-linux/ ./browser/
# Copy Go binary
COPY --from=go-builder /vulpineos ./vulpineos
# Copy settings
COPY settings/ ./browser/
# Copy entrypoint
COPY scripts/entrypoint.sh ./entrypoint.sh
RUN chmod +x ./entrypoint.sh ./vulpineos

# Create vault directory
RUN mkdir -p /root/.vulpineos

ENV DISPLAY=:99
EXPOSE 8443

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD if [ -n "$VULPINE_TLS_CERT" ] && [ -n "$VULPINE_TLS_KEY" ]; then curl -skf https://localhost:8443/health; else curl -sf http://localhost:8443/health; fi || exit 1

ENTRYPOINT ["./entrypoint.sh"]

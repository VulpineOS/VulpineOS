{
  "name": "vulpineos",
  "version": "0.1.0",
  "description": "VulpineOS: stealth-aware AI browser agent runtime with browser-engine security.",
  "private": true,
  "scripts": {
    "postinstall": "echo 'VulpineOS dependencies installed. OpenClaw is ready.'",
    "build-go": "go build -o vulpineos ./cmd/vulpineos/",
    "setup": "go build -o vulpineos ./cmd/vulpineos/ && ./vulpineos --no-browser",
    "benchmark:tokens": "node benchmarks/token-optimization/benchmark.mjs"
  },
  "dependencies": {
    "openclaw": "latest"
  },
  "devDependencies": {
    "gpt-tokenizer": "^3.4.0"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/VulpineOS/VulpineOS"
  },
  "license": "MPL-2.0"
}
